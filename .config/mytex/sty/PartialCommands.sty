\newcounter{partialNumber}
\newcommand{\thepartial}{}
\newcommand{\setpartialnumber}[1]{
  \setcounter{partialNumber}{#1}
  \ifthenelse{#1 = 1}{
    \renewcommand{\thepartial}{Primer }
  }{
    \ifthenelse{#1 = 2}{
    \renewcommand{\thepartial}{Segundo }
  }{
    \ifthenelse{#1 = 3}{
    \renewcommand{\thepartial}{Tercer }
    }{
    \renewcommand{\thepartial}{Cuarto }
    }
  }
  }
}
\newcommand{\classname}{}
\newcommand{\setclass}[1]{
  \ifthenelse{\equal{#1}{\string FS0121}}{
    \renewcommand{\classname}{FS-0121 Fundamentos de Física}
  }{
  \ifthenelse{\equal{#1}{\string FS0210}}{
    \renewcommand{\classname}{FS-0210 Física General I}
  }{
  \ifthenelse{\equal{#1}{\string FS0310}}{
    \renewcommand{\classname}{FS-0310 Física General II}
  }{
  \ifthenelse{\equal{#1}{\string FS0410}}{
    \renewcommand{\classname}{FS-0410 Física General III}
  }{
  \ifthenelse{\equal{#1}{\string FS0230}}{
    \renewcommand{\classname}{FS-0230 Física I}
  }{
  \ifthenelse{\equal{#1}{\string FS0330}}{
    \renewcommand{\classname}{FS-0330 Física II}
  }{
  \ifthenelse{\equal{#1}{\string FS0430}}{
    \renewcommand{\classname}{FS-0430 Física III}
  }{
    \renewcommand{\classname}{#1}
  } } } } } } }
}

\newcommand{\thecycle}{0000-III}
\newcommand{\setcycle}[1]{
  \renewcommand{\thecycle}{#1}
}
\newcommand{\thegroup}{Grupo 00}
\newcommand{\setgroup}[1]{
  \renewcommand{\thegroup}{Grupo #1}
}
\newcommand{\testdefinition}[3]{
  \setgroup{#1}
  \setcycle{#2}
  \setpartialnumber{#3}
}

\newcommand{\question}[2]{
  \item 
  \addcontentsline{toc}{subsection}{Pregunta \theenumi}
    #1
  \ifthenelse{\boolean{solutions}}{
    #2
  }{}
}
\newcommand{\qpart}[2]{
  \item
  #1
  \ifthenelse{\boolean{solutions}}{
    \paragraph{Solución:}
    #2
  }{}
}
\newcommand{\ptsdistro}{
  \paragraph{Distribución de puntos}
  \renewcommand{\labelenumiv}{\theenumi\theenumiii-\arabic{enumiv})}
}
\newcommand{\pts}[1]{(\textit{#1 pts.})}
\newcommand{\upt}{(\textit{1 pt.})}
\newcommand{\uptcu}{(\textit{1 pt c/u.})}
\newcommand{\ptscu}[1]{(\textit{#1 pts c/u.})}

